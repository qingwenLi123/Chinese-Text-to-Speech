[Unit]
Description=Chinese TTS Web Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Chinese-Text-to-Speech
Environment="PATH=/root/Chinese-Text-to-Speech/venv/bin"
ExecStart=/root/Chinese-Text-to-Speech/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 --timeout 300 app:app
Restart=on-failure

[Install]
WantedBy=multi-user.target
